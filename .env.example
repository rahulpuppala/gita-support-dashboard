# AI Service
OPENAI_API_KEY=your_openai_key

# Database
DATABASE_PATH=./data/support.db

# WhatsApp
WHATSAPP_SESSION_PATH=./sessions/whatsapp

# Website Scraping (comma-separated URLs)
WEBSITE_URLS=https://webex-usa.chinmayavrindavan.org

# Google Drive Integration (optional)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
GOOGLE_DRIVE_CREDENTIALS_PATH=./google-credentials.json

# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_random_secret

# Bot Behavior
MIN_RESPONSE_DELAY=45000
MAX_RESPONSE_DELAY=75000
ENABLE_TYPING_INDICATOR=true
